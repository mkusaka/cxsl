{
  "name": "cxsl",
  "version": "0.1.0",
  "description": "Slack gateway for Codex app-server",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --env-file-if-exists=.env src/app.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.ts",
    "start": "node --env-file-if-exists=.env dist/app.js",
    "generate:codex-schema": "codex app-server generate-ts --out .codex-schema/app-server"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@slack/types": "2.21.1",
    "@types/node": "25.9.4",
    "typescript": "6.0.3"
  }
}
