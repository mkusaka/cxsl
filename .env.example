# Slack credentials. Replace locally; do not commit real tokens.
SLACK_BOT_TOKEN=replace-with-bot-token
SLACK_APP_TOKEN=replace-with-app-level-token

# SQLite state.
DATABASE_PATH=.data/cxsl.sqlite

# Codex app-server command. CODEX_ARGS may be JSON or whitespace-separated.
CODEX_COMMAND=codex
CODEX_ARGS=["app-server"]
CODEX_DEFAULT_CWD=.
CODEX_DEFAULT_MODEL=
CODEX_APPROVAL_POLICY=on-request
CODEX_SANDBOX=workspace-write

# Optional Slack allowlists. Leave blank to allow all users/channels.
SLACK_ALLOWED_USER_IDS=
SLACK_ALLOWED_CHANNEL_IDS=

LOG_LEVEL=info
